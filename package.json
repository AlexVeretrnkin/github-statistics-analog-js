{
  "name": "github-statistics-analog-js",
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.1"
  },
  "scripts": {
    "ng": "ng",
    "dev": "NODE_OPTIONS=--experimental-sqlite vite",
    "start": "pnpm run dev",
    "build": "NODE_OPTIONS=--experimental-sqlite vite build",
    "watch": "NODE_OPTIONS=--experimental-sqlite vite build --watch",
    "graphql:codegen": "node --env-file=.env ./node_modules/@graphql-codegen/cli/cjs/bin.js --config codegen.ts",
    "test": "NODE_OPTIONS=--experimental-sqlite vitest",
    "preview": "node --experimental-sqlite dist/analog/server/index.mjs"
  },
  "private": true,
  "dependencies": {
    "@analogjs/content": "^2.3.1",
    "@analogjs/router": "^2.3.1",
    "@angular/animations": "^21.0.0",
